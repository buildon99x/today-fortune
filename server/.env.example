# 서버에서만 사용. 절대 클라이언트/저장소에 커밋하지 마세요.
# CLI 모드(LLM_PROVIDER=cli)에선 비어 있어도 됨.
ANTHROPIC_API_KEY=sk-ant-...

# === LLM 제공자 선택 ===
# api (기본): Anthropic SDK + ANTHROPIC_API_KEY. 운영은 반드시 이쪽.
# cli       : 로컬 `claude -p` CLI. API 키 없이 dev iteration. NODE_ENV=production에선 부팅 거부.
#             느림(25-40s/호출), 모델이 다름(Claude Code 기본=Opus 계열),
#             구조화출력/캐싱/사용량 미보고. 진지한 프롬프트 튜닝은 api 권장.
# LLM_PROVIDER=api
# CLAUDE_CLI_TIMEOUT_MS=90000

# 운영 환경에선 명시적으로 production 선언 — LLM_PROVIDER=cli 실수 차단.
# NODE_ENV=production

# 선택: 운세 생성 모델(기본 claude-haiku-4-5). 품질을 높이려면 claude-opus-4-7 등으로 변경.
# CLI 모드에선 무시됨(Claude Code 기본 모델 사용).
FORTUNE_MODEL=claude-haiku-4-5

# 선택: judge 채점 모델(기본 claude-sonnet-4-6).
# Sonnet은 시스템 프롬프트(채점기준+예시)가 캐시 임계(2048)를 넘어 cache_read 0.1× 가격으로 작동.
# Haiku로 두면 캐시 임계(4096) 미달이라 매번 풀 비용 — 채점은 반복 호출이라 Sonnet이 결과적으로 더 싸고 빠름.
# 주기적 교차 검증은 Opus로 별도 실행(scripts/batch-eval).
# JUDGE_MODEL=claude-sonnet-4-6

# === 프라이버시 (P0/P1) ===
# 모든 캐시/레이트리밋/리플레이 키는 HMAC-SHA256으로 해시 저장 — 시크릿 필수.
# 미설정 시 SHA-256 폴백 + 부팅 경고. 운영에선 반드시 32바이트 랜덤값 설정:
#   openssl rand -hex 32
# PRIVACY_HMAC_SECRET=...

# 캐시 TTL(초). 기본 0(완전 비활성 — "휘발" 정책 일치, 캐시 타이밍 oracle 차단).
# 비용 절감을 위해 활성화 가능하나, 동일 입력 재요청 시 응답시간 차이로
# "이미 조회된 프로필" 추정 가능 — 가족/지인 명단 대조 공격 표면.
# FORTUNE_CACHE_TTL_SEC=0

# 선택: CORS 허용 오리진(기본 *). 운영에선 토스 웹뷰 오리진으로 제한.
ALLOWED_ORIGIN=*

# 선택: 포트(기본 8787)
PORT=8787

# 선택: Upstash Redis / Vercel KV (운영 권장).
# 둘 중 한 쌍이라도 있으면 캐시·레이트리밋·리플레이 방어가 Redis 기반으로 자동 전환.
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...

# === 영수증/광고 검증 === (env가 있는 플랫폼만 자동 활성화. 하나도 없으면 /unlock 은 501)

# Apple StoreKit2 (iOS)
# APPLE_BUNDLE_ID=com.example.fortune
# APPLE_PRODUCT_IDS=fortune.full_reading,fortune.monthly
# Apple Root CA G3의 sha256 지문(콜론 hex). https://www.apple.com/certificateauthority/ 에서 확인.
# APPLE_ROOT_CERT_FINGERPRINT_SHA256=AB:CD:...
# 또는 PEM을 두면 부팅 시 지문이 계산됨:
# APPLE_ROOT_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Google Play Billing (Android)
# GOOGLE_PACKAGE_NAME=com.example.fortune
# GOOGLE_PRODUCT_IDS=fortune.full_reading,fortune.monthly
# GOOGLE_SERVICE_ACCOUNT_JSON 은 Play Console 권한 부여된 GCP 서비스 계정 JSON 전체(문자열)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"..."}

# 보상형 광고 서버 콜백 (광고 네트워크와 공유하는 시크릿)
# AD_CALLBACK_SECRET=...
